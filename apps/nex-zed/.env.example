# nex-zed configuration
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will never be committed.

# LLM backend (DeepSeek, OpenAI, Ollama, etc.)
LLM_BASE_URL="https://api.com"
LLM_MODEL="model"
LLM_API_KEY="your-key-here"

# Optional overrides
# LLM_SYSTEM_PROMPT="You are a helpful coding assistant."
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT=300

# Session limits
# LLM_MAX_SESSIONS=10
# LLM_SESSION_IDLE_TIMEOUT=3600
# LLM_MAX_HISTORY_TURNS=50

# A2A HTTP server (optional)
# A2A_HOST="0.0.0.0"
# A2A_PORT=8080
