# RAG engine defaults — copy to .env and edit
LMSTUDIO_URL=http://localhost:1234
LLM_MODEL=liquid/lfm2.5-1.2b
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_DIM=768

# LightRAG
LIGHTRAG_PORT=9621
LIGHTRAG_DATA=./lightrag/data

# EdgeQuake (prebuilt GHCR)
EDGEQUAKE_VERSION=latest
EDGEQUAKE_PULL=missing
EDGEQUAKE_PORT=8080
POSTGRES_PASSWORD=edgequake_secret
POSTGRES_PORT=5432
RUST_LOG=info
